#!/usr/bin/env bash
# Build release archives for macOS (amd64, arm64)
# Run scripts/release first to bump and tag the version.
#
# Optional env vars:
#   SDKROOT          Path to macOS SDK (for sysroot flags, e.g. xcrun --show-sdk-path)
#   MACOS_MIN_VERSION  Minimum macOS deployment target (default: 11.0)
#   ZIG              Path to zig binary (default: zig)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
DIST_DIR="$REPO_ROOT/dist"
WEB_UI_DIR="$REPO_ROOT/web-ui"
ZIG="${ZIG:-zig}"
MACOS_MIN_VERSION="${MACOS_MIN_VERSION:-11.0}"

# Auto-detect SDKROOT on macOS if not set
if [ -z "${SDKROOT:-}" ] && command -v xcrun >/dev/null 2>&1; then
    SDKROOT="$(xcrun --show-sdk-path 2>/dev/null || true)"
fi
SDKROOT="${SDKROOT:-}"

cd "$REPO_ROOT"

# Ensure zig is available (needed for cross-compilation)
if ! command -v "$ZIG" >/dev/null 2>&1; then
    echo "Error: zig not found. Install it from https://ziglang.org/download/" >&2
    exit 1
fi

# Get version from latest git tag (same as Makefile)
VERSION="$(git describe --tags --abbrev=0 2>/dev/null || echo dev)"
LDFLAGS="-s -w -X github.com/digiogithub/pando/internal/version.Version=${VERSION}"

echo "Version: ${VERSION}"
echo "macOS minimum deployment target: ${MACOS_MIN_VERSION}"
[ -n "$SDKROOT" ] && echo "SDKROOT: ${SDKROOT}"

# Build embedded web-ui assets
echo "Building web-ui embedded assets..."
cd "$WEB_UI_DIR"
bun install
bun run build:embedded
cd "$REPO_ROOT"

mkdir -p "$DIST_DIR"

# Build sysroot env vars when SDKROOT is set.
# -isysroot sets header search path; -L flags are needed for zig to locate
# dynamic system libraries (.tbd stubs) like libresolv.
sysroot_env=()
if [ -n "$SDKROOT" ]; then
    sysroot_env+=(
        CGO_CFLAGS="-isysroot $SDKROOT"
        CGO_CXXFLAGS="-isysroot $SDKROOT"
        CGO_LDFLAGS="-isysroot $SDKROOT -L${SDKROOT}/usr/lib -L${SDKROOT}/usr/lib/system"
    )
fi

build_archive() {
    local goos="$1"
    local goarch="$2"
    local artifact_name="$3"
    shift 3
    local env_vars=("$@")

    local out="$DIST_DIR/pando-${artifact_name}"
    echo "Building ${goos}/${goarch} → pando-${artifact_name}.zip ..."
    env GOOS="$goos" GOARCH="$goarch" CGO_ENABLED=1 "${env_vars[@]}" ${sysroot_env[@]+"${sysroot_env[@]}"} \
        go build -ldflags "$LDFLAGS" -o "$out" .
    (cd "$DIST_DIR" && zip -qm "pando-${artifact_name}.zip" "pando-${artifact_name}")
    echo "  → dist/pando-${artifact_name}.zip"
}

# macOS amd64 (cross-compiled via zig)
CC_DARWIN_AMD64="${ZIG} cc -target x86_64-macos.${MACOS_MIN_VERSION}"
CXX_DARWIN_AMD64="${ZIG} c++ -target x86_64-macos.${MACOS_MIN_VERSION}"
build_archive darwin amd64 darwin-x64 \
    CC="$CC_DARWIN_AMD64" CXX="$CXX_DARWIN_AMD64"

# macOS arm64 / Apple Silicon (cross-compiled via zig)
CC_DARWIN_ARM64="${ZIG} cc -target aarch64-macos.${MACOS_MIN_VERSION}"
CXX_DARWIN_ARM64="${ZIG} c++ -target aarch64-macos.${MACOS_MIN_VERSION}"
build_archive darwin arm64 darwin-arm64 \
    CC="$CC_DARWIN_ARM64" CXX="$CXX_DARWIN_ARM64"

echo ""
echo "Done. Artifacts in dist/:"
ls -lh "$DIST_DIR"/*.zip
