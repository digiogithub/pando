{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "agent": {
      "description": "Agent configuration",
      "properties": {
        "maxTokens": {
          "description": "Maximum tokens for the agent",
          "minimum": 1,
          "type": "integer"
        },
        "model": {
          "description": "Model ID for the agent",
          "enum": [
            "azure.gpt-4o-mini",
            "azure.o3",
            "azure.o1-mini",
            "azure.o4-mini",
            "azure.gpt-4.1-mini",
            "vertexai.gemini-2.5",
            "vertexai.gemini-2.5-flash",
            "azure.gpt-4.1-nano",
            "azure.gpt-4.5-preview",
            "azure.gpt-4o",
            "azure.o1",
            "azure.gpt-4.1",
            "azure.o3-mini",
            "bedrock.claude-3.7-sonnet"
          ],
          "type": "string"
        },
        "reasoningEffort": {
          "description": "Reasoning effort for models that support it (OpenAI, Anthropic)",
          "enum": [
            "low",
            "medium",
            "high"
          ],
          "type": "string"
        }
      },
      "required": [
        "model"
      ],
      "type": "object"
    }
  },
  "description": "Configuration schema for the Pando application",
  "properties": {
    "agents": {
      "additionalProperties": {
        "description": "Agent configuration",
        "properties": {
          "maxTokens": {
            "description": "Maximum tokens for the agent",
            "minimum": 1,
            "type": "integer"
          },
          "model": {
            "description": "Model ID for the agent",
            "enum": [
              "azure.gpt-4o-mini",
              "azure.o3",
              "azure.o1-mini",
              "azure.o4-mini",
              "azure.gpt-4.1-mini",
              "vertexai.gemini-2.5",
              "vertexai.gemini-2.5-flash",
              "azure.gpt-4.1-nano",
              "azure.gpt-4.5-preview",
              "azure.gpt-4o",
              "azure.o1",
              "azure.gpt-4.1",
              "azure.o3-mini",
              "bedrock.claude-3.7-sonnet"
            ],
            "type": "string"
          },
          "reasoningEffort": {
            "description": "Reasoning effort for models that support it (OpenAI, Anthropic)",
            "enum": [
              "low",
              "medium",
              "high"
            ],
            "type": "string"
          }
        },
        "required": [
          "model"
        ],
        "type": "object"
      },
      "description": "Agent configurations",
      "properties": {
        "coder": {
          "$ref": "#/definitions/agent"
        },
        "task": {
          "$ref": "#/definitions/agent"
        },
        "title": {
          "$ref": "#/definitions/agent"
        }
      },
      "type": "object"
    },
    "contextPaths": {
      "default": [
        ".github/copilot-instructions.md",
        ".cursorrules",
        ".cursor/rules/",
        "CLAUDE.md",
        "CLAUDE.local.md",
        "pando.md",
        "pando.local.md",
        "Pando.md",
        "Pando.local.md",
        "PANDO.md",
        "PANDO.local.md"
      ],
      "description": "Context paths for the application",
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "data": {
      "description": "Storage configuration",
      "properties": {
        "directory": {
          "default": ".pando",
          "description": "Directory where application data is stored",
          "type": "string"
        }
      },
      "required": [
        "directory"
      ],
      "type": "object"
    },
    "debug": {
      "default": false,
      "description": "Enable debug mode",
      "type": "boolean"
    },
    "debugLSP": {
      "default": false,
      "description": "Enable LSP debug mode",
      "type": "boolean"
    },
    "lsp": {
      "additionalProperties": {
        "description": "LSP configuration for a language",
        "properties": {
          "args": {
            "description": "Command arguments for the LSP server",
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "command": {
            "description": "Command to execute for the LSP server",
            "type": "string"
          },
          "disabled": {
            "default": false,
            "description": "Whether the LSP is disabled",
            "type": "boolean"
          },
          "options": {
            "description": "Additional options for the LSP server",
            "type": "object"
          }
        },
        "required": [
          "command"
        ],
        "type": "object"
      },
      "description": "Language Server Protocol configurations",
      "type": "object"
    },
    "mcpServers": {
      "additionalProperties": {
        "description": "MCP server configuration",
        "properties": {
          "args": {
            "description": "Command arguments for the MCP server",
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "command": {
            "description": "Command to execute for the MCP server",
            "type": "string"
          },
          "env": {
            "description": "Environment variables for the MCP server",
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "headers": {
            "additionalProperties": {
              "type": "string"
            },
            "description": "HTTP headers for SSE and streamable-http type MCP servers",
            "type": "object"
          },
          "type": {
            "default": "stdio",
            "description": "Type of MCP server",
            "enum": [
              "stdio",
              "sse",
              "streamable-http"
            ],
            "type": "string"
          },
          "url": {
            "description": "URL for SSE and streamable-http type MCP servers",
            "type": "string"
          }
        },
        "type": "object"
      },
      "description": "Model Control Protocol server configurations",
      "type": "object"
    },
    "mesnada": {
      "description": "Mesnada integration configuration",
      "properties": {
        "acp": {
          "description": "Mesnada ACP configuration",
          "properties": {
            "autoPermission": {
              "description": "Automatically approve ACP permissions",
              "type": "boolean"
            },
            "defaultAgent": {
              "description": "Default ACP agent for Mesnada",
              "type": "string"
            },
            "enabled": {
              "description": "Enable ACP-backed Mesnada agents",
              "type": "boolean"
            }
          },
          "type": "object"
        },
        "enabled": {
          "default": false,
          "description": "Enable Mesnada integration",
          "type": "boolean"
        },
        "orchestrator": {
          "description": "Mesnada orchestrator configuration",
          "properties": {
            "defaultEngine": {
              "default": "copilot",
              "description": "Default engine for Mesnada tasks",
              "type": "string"
            },
            "defaultMcpConfig": {
              "description": "Default MCP config for Mesnada tasks",
              "type": "string"
            },
            "logDir": {
              "description": "Directory for Mesnada task logs",
              "type": "string"
            },
            "maxParallel": {
              "default": 5,
              "description": "Maximum number of parallel Mesnada tasks",
              "type": "integer"
            },
            "personaPath": {
              "description": "Path to Mesnada persona definitions",
              "type": "string"
            },
            "storePath": {
              "description": "Path to the Mesnada task store",
              "type": "string"
            }
          },
          "type": "object"
        },
        "server": {
          "description": "Mesnada HTTP server configuration",
          "properties": {
            "host": {
              "default": "127.0.0.1",
              "description": "Mesnada server host",
              "type": "string"
            },
            "port": {
              "default": 9767,
              "description": "Mesnada server port",
              "type": "integer"
            }
          },
          "type": "object"
        },
        "tui": {
          "description": "Mesnada TUI configuration",
          "properties": {
            "enabled": {
              "default": true,
              "description": "Enable Mesnada TUI features",
              "type": "boolean"
            },
            "webui": {
              "default": true,
              "description": "Enable the Mesnada web UI",
              "type": "boolean"
            }
          },
          "type": "object"
        }
      },
      "type": "object"
    },
    "providers": {
      "additionalProperties": {
        "description": "Provider configuration",
        "properties": {
          "apiKey": {
            "description": "API key for the provider",
            "type": "string"
          },
          "disabled": {
            "default": false,
            "description": "Whether the provider is disabled",
            "type": "boolean"
          },
          "provider": {
            "description": "Provider type",
            "enum": [
              "anthropic",
              "openai",
              "gemini",
              "groq",
              "openrouter",
              "bedrock",
              "azure",
              "vertexai"
            ],
            "type": "string"
          }
        },
        "type": "object"
      },
      "description": "LLM provider configurations",
      "type": "object"
    },
    "skills": {
      "description": "Skill discovery and prompt injection configuration",
      "properties": {
        "enabled": {
          "default": true,
          "description": "Enable skills support",
          "type": "boolean"
        },
        "paths": {
          "description": "Additional skill search paths",
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "type": "object"
    },
    "tui": {
      "description": "Terminal User Interface configuration",
      "properties": {
        "theme": {
          "default": "pando",
          "description": "TUI theme name",
          "enum": [
            "pando",
            "catppuccin",
            "dracula",
            "flexoki",
            "gruvbox",
            "monokai",
            "onedark",
            "tokyonight",
            "tron"
          ],
          "type": "string"
        }
      },
      "type": "object"
    },
    "internalTools": {
      "description": "Built-in tool integrations configuration",
      "properties": {
        "fetchEnabled": {
          "default": true,
          "description": "Enable the fetch/HTTP tool",
          "type": "boolean"
        },
        "fetchMaxSizeMB": {
          "default": 10,
          "description": "Maximum response size in MB for the fetch tool",
          "type": "integer"
        },
        "googleSearchEnabled": {
          "default": true,
          "description": "Enable Google Custom Search tool",
          "type": "boolean"
        },
        "googleApiKey": {
          "description": "Google Custom Search API key",
          "type": "string"
        },
        "googleSearchEngineId": {
          "description": "Google Custom Search Engine ID",
          "type": "string"
        },
        "braveSearchEnabled": {
          "default": true,
          "description": "Enable Brave Search tool",
          "type": "boolean"
        },
        "braveApiKey": {
          "description": "Brave Search API key",
          "type": "string"
        },
        "perplexitySearchEnabled": {
          "default": true,
          "description": "Enable Perplexity AI Search tool",
          "type": "boolean"
        },
        "perplexityApiKey": {
          "description": "Perplexity AI Search API key",
          "type": "string"
        },
        "exaSearchEnabled": {
          "default": true,
          "description": "Enable Exa AI Search tool",
          "type": "boolean"
        },
        "exaApiKey": {
          "description": "Exa AI Search API key",
          "type": "string"
        },
        "context7Enabled": {
          "default": true,
          "description": "Enable Context7 library docs tool",
          "type": "boolean"
        },
        "browserEnabled": {
          "default": false,
          "description": "Enable browser automation tools (requires Chrome/Chromium in PATH)",
          "type": "boolean"
        },
        "browserHeadless": {
          "default": true,
          "description": "Run browser in headless mode",
          "type": "boolean"
        },
        "browserTimeout": {
          "default": 30,
          "description": "Default browser operation timeout in seconds",
          "minimum": 5,
          "maximum": 300,
          "type": "integer"
        },
        "browserUserDataDir": {
          "description": "Path to Chrome user data directory (optional, uses temp dir if empty)",
          "type": "string"
        },
        "browserMaxSessions": {
          "default": 3,
          "description": "Maximum number of concurrent browser sessions",
          "minimum": 1,
          "maximum": 10,
          "type": "integer"
        }
      },
      "type": "object"
    },
    "wd": {
      "description": "Working directory for the application",
      "type": "string"
    },
    "personaAutoSelect": {
      "description": "Automatic persona selection for the main conversation session",
      "properties": {
        "enabled": {
          "default": false,
          "description": "Activate automatic persona selection before each user message. Uses agents[\"persona-selector\"] model.",
          "type": "boolean"
        },
        "personaPath": {
          "description": "Directory containing persona .md files. Falls back to mesnada.orchestrator.personaPath when empty.",
          "type": "string"
        }
      },
      "type": "object"
    }
  },
  "title": "Pando Configuration",
  "type": "object"
}
